APP_ENV=prod
DATABASE_URL=postgresql+psycopg2://user:password@localhost/fuel_monitor
TIMEZONE=Europe/Istanbul

TURPAK_ENABLED=true
TURPAK_COMPANY_NAME=
TURPAK_PASSWORD=
TURPAK_GROUP_NAME=#TSM BINEK ARAC

SHELL_ENABLED=true
SHELL_USE_API=true
SHELL_BASE_URL=https://tts.turkiyeshell.com/TTS/TTSWebServices.asmx
SHELL_CUSTOMER_CODE=
SHELL_USER_ID=
SHELL_PASSWORD=
SHELL_BRANCH_CODE=
SHELL_TIMEOUT_SECONDS=120
SHELL_FILE_FALLBACK_ENABLED=true
SHELL_INPUT_PATH=
SHELL_INPUT_DIR=
SHELL_GLOB=*.xlsx

PETROL_ENABLED=true
PETROL_USE_API=true
PETROL_USER_NAME=
PETROL_USER_PASSWORD=
PETROL_PROXY_URL=

SCHEDULER_ENABLED=false
SCHEDULER_MORNING_HOUR=7
SCHEDULER_EVENING_HOUR=18
